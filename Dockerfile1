# Single-stage build with Ubuntu 24.04
FROM ubuntu:24.04

# Set noninteractive and enable detailed logging
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Minimal package installation with error logging
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
     python3 \
     python3-pip \
     python3-venv \
     graphviz \
     imagemagick \
     python3-graphviz \
     python3-pyqt5 \
     libgl1 \
     libxcb-xinerama0 \
     libxcb-icccm4 \
     libxcb-image0 \
     xdg-utils \
     x11-utils \
	texlive-science \
	texlive-latex-extra \
	dvipng\
	imagemagick\
	python3-simplejson \
	python3-ujson \
    evince



RUN xdg-mime default evince.desktop application/pdf


# Create and activate a virtual environment
RUN python3 -m venv /opt/venv \
 && /opt/venv/bin/pip install --no-cache-dir graphviz

# Set environment variables for later commands
ENV PATH="/opt/venv/bin:$PATH"



# Create a non-root user
RUN useradd -m appuser

# Copy and install Python dependencies
COPY requirements.txt /tmp/
RUN pip3 install --upgrade pip && \
    pip3 install --no-cache-dir -r /tmp/requirements.txt || true

# Set Qt plugin path
ENV QT_QPA_PLATFORM_PLUGIN_PATH="/usr/lib/python3/dist-packages/PyQt5/qt5/plugins"

# Set comprehensive X11 and graphics environment variables
ENV DISPLAY=:0
ENV QT_X11_NO_MITSHM=1
ENV QT_QPA_PLATFORM=xcb
ENV XDG_RUNTIME_DIR=/tmp/runtime-appuser

# Disable specific OpenGL extensions that might cause issues
ENV LIBGL_ALWAYS_SOFTWARE=1

# Create directory structure
RUN mkdir -p /ProMo/tasks /Ontology_Repository
WORKDIR /ProMo

# Copy application files
COPY ./tasks/ tasks/
COPY ./packages/ packages/
COPY ./src/ src/
COPY . .

# Set permissions
RUN chmod 0700 /ProMo/tasks
RUN chmod +x tasks/*.sh

WORKDIR /ProMo/tasks

CMD ["python3", "run.py"]

