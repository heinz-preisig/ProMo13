{
  "variable_with_index": "{variable_name}({index_list})",
  "variable_no_index": "{variable_name}",
  "index": "{index_alias}",
  "addition": "{op1} + {op2}",
  "substraction": "{op1} - {op2}",
  "negation": "-{op1}",
  "einstein_sum": "einsum({op1}, {op2})",
  "einstein_sum_contraction": "einsum({op1}, {op2}, {{\"{idx}\"}})",
  "expand_product": "expandproduct({op1}, {op2})",
  "hadamard": "{op1} .* {op2}",
  "reduce_product": "{op1} * {op2}",
  "power": "{op1} .^ {op2}",
  "parentheses": "({op1})",
  "exp": "exp({op1})",
  "log": "log10({op1})",
  "ln": "log({op1})",
  "sqrt": "sqrt({op1})",
  "sin": "sin({op1})",
  "cos": "cos({op1})",
  "tan": "tan({op1})",
  "asin": "asin({op1})",
  "acos": "acos({op1})",
  "atan": "atan({op1})",
  "abs": "abs({op1})",
  "neg": "-1 .* {op1}",
  "diffspace": "diffspace({op1})",
  "left": "left({op1})",
  "right": "right({op1})",
  "inv": "1 ./ {op1}",
  "sign": "sign({op1})",
  "par_diff": "pardiff({op1}, {op2})",
  "total_diff": "totaldiff({op1}, {op2})",
  "instantiate": "instantiate({op1}, {op2})",
  "product": "product({op1}, \"{idx1}\")",
  "integral": "integral({op1}, {op2}, {op3}, {op4})",
  "root": "{op1}"
}
