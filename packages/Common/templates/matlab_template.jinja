function output_vars = main
  % Index sets
  {% for set_name, set_info in index_sets_info|items %}
    {{-"  "}}{{set_name}} = [{{set_info|join(",")}}]; {{"\n"-}}
    {{-"  "}}{{set_name}}_lbl = "{{set_name}}";
  {% endfor %}

  {{-"  "}}indexOrder = cell(1, {{index_order|length}});
  {% for element in index_order %}
    {{-"  "}}indexOrder({{loop.index}})  = {{element}}_lbl;
  {% endfor %}

  % Variables
  {% for var in variables %}
    {% if var.comment %}
      {% for com in var.comment%}
        {{-"  "}}% {{com}}
      {% endfor %}
    {% endif %}

    {{-"  "}}{{var.var_id|label}} = MultiDimVar(
      {{-""}}{ {{-var.index_labels-}} }, 
      {{-" "}}[ {{-var.size|join(",")-}} ],
      {{-" "}}indexOrder
    {{-""}});{{-"\n"-}}

    {% for index_tuple, value in var.instantiation_values|items %}
      {{-"  "}}{{var.var_id|label}}({{index_tuple|join(",")}}) = {{value}};
    {% endfor%}

    {% if var.is_sparse %}
      {{-"  "}}{{var.var_id|label}} = sparse({{var.var_id|label}});
    {% endif %}
    {{-"\n"-}}
  {% endfor%}

  % Integrators
  % Index sets
  {% for i in integrators %}
    {% for index_set_name, indices_list in i.index_sets|items %}
      {{-"  "}}{{index_set_name}} = [{{indices_list|join(",")}}];
    {% endfor %}
  {% endfor %}
  % Initial conditions
  {% for i in integrators %}
    {{-"  "}}phi_0({{i.interval}}) =
      {{-" "}}reshape({{i.init_value|label}}.value({{i.index_sets|join(',')}}), [], 1);
  {% endfor %}

  % Integration interval
  integration_interval = [
    {{-(integrators|first).int_interval_ini|label-}}.value,
    {{-" "}}{{(integrators|first).int_interval_fin|label-}}.value
  {{-""}}];{{"\n"-}}

  {{-"  "}}dt = 0.1;{{"\n"-}}
  {{-"  "}}options = odeset('InitialStep', dt, 'MaxStep', dt, 'RelTol', 1e-3, 'AbsTol', 1e-3);{{"\n"-}}

  {{-"  "}}% Integrator routine
  [t, phi] = ode45(@f, integration_interval, phi_0, options);

  % Printing output
  % HEADERS{{"\n"-}}
  {{-"  "}}fprintf("%s", "time");
  {% for var_id, var_data in print_info|items %}
    {% for ref_var_info in var_data %}
      {{-"  "}}fprintf("\t%s", "{{var_id|label}}:{{ref_var_info.extra_name}}");
    {% endfor %}
  {% endfor %}
  {{-"  "}}fprintf("\n");

  % DATA
  time_steps = length(t);
  for i = 1:time_steps
    [integrand, other_vars] = f(t(i), phi(i,:));
    fprintf("%d\t", t(i));
    fprintf("%d\t", other_vars);
    fprintf("\n");
  endfor

  % Integrands
  function [dphidt, extra_output] = f(t, phi) {{"\n"-}}
    {% for i in integrators %}
      {{-"    "}}{{i.var_id|label}}.value({{i.index_sets|join(',')}}) =
        {{-" "}}reshape(phi({{i.interval}}), {{i.size_by_index|join(",")}});{{"\n"-}}
    {% endfor %}

    {% for expr in expressions %}
      {% if expr.type == "simple" %}
        {% for index_set_name, indices_list in expr.equations[0].index_sets|items %}
        {{-"    "}}{{index_set_name}} = [{{indices_list|join(",")}}];
        {% endfor %}
        {{-"    "}}{{expr.equations[0].var_id|var_slice(expr.equations[0].index_sets)}} = 
          {{-" "}}{{expr.id}}({{expr|dependencies}});
      {% else %}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% {{expr.id}} %%%%%%%%%%%%%%%%%%%%%%%%%%%%%{{"\n"}}
        {{-"    "}}sol = {{expr.id}}({{expr|dependencies}});{{"\n"}}
        {% for eq in expr.equations %}
          {% for index_set_name, indices_list in eq.index_sets|items %}
            {{-"    "}}{{index_set_name}} = [{{indices_list|join(",")}}];
          {% endfor %}
          {{-"    "}}{{eq.var_id|var_slice(eq.index_sets)}} = 
            {{-" "}}sol({{eq.interval}});
        {% endfor %}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
      {% endif %}
      {{-"\n"-}}
    {% endfor %}

    {{-"    "}}extra_output = [
    {% for var_id, var_data in print_info|items %}
      {% for ref_var_info in var_data %}
        {{-"      "}}{{var_id|label}}.value({{ref_var_info.position|join(",")}});
      {% endfor %}
    {% endfor %}
    ];

    {% for i in integrators %}
      {{-"    "}}dphidt({{i.interval}}) = 
        {{-" "}}reshape({{i.integrand|label}}.value({{i.index_sets|join(',')}}), [], 1);
    {% endfor %}
  endfunction
endfunction

% Functions for the equations
{% for expr in expressions %}
  {% if expr.type == "simple" %}
    {{-""}}function sol = {{expr.id}}({{expr.equations|first|arguments}})
      {% set eq = expr.equations|first%}
      {{-"  "}}sol = {{eq.eq_id|eq_label("rhs")}};{{"\n"}}
    {{-""}}endfunction{{"\n"}}
  {% else %}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% {{expr.id}} %%%%%%%%%%%%%%%%%%%%%%%%%%%%%{{"\n"}}
    {{-""}}function sol = {{expr.id}}({{expr|dependencies}}){{"\n"}}
      {{-"  "}}% Load initial conditions for the solvers{{"\n"}}
      {{-"  "}}run("init.m");{{"\n"}}
      {{-"  "}}initial_guess = {{expr.id}}_init;{{"\n"}}
      {{-"  "}}sol = {{solvers.sys_of_equations}}(@sys, initial_guess);{{"\n\n"}}

      {{-"  "}}function F = sys(x)
        {% for eq in expr.equations %}
          {% for index_set_name, indices_list in eq.index_sets|items %}
            {{-"    "}}{{index_set_name}} = [{{indices_list|join(",")}}];
          {% endfor %}
          {{-"    "}}{{eq.var_id|label}}.value({{eq.index_sets|join(',')}}) = x({{eq.interval}});
        {% endfor %}
        {{-"\n"-}}
        {% for eq in expr.equations %}
            {{-"    "}}F({{eq.interval}}) = res_{{eq.eq_id}}({{ {"type":"simple", "equations":[eq]}|dependencies}});
        {% endfor %}
      {{-"  "}}endfunction{{"\n"}}
    {{-""}}endfunction{{"\n"}}
    {{-"\n"-}}
    {{-""}}% Residue equations
    {% for eq in expr.equations %}
      {{-""}}function sol = res_{{eq.eq_id}}({{eq|arguments}})
      {{-"\n"-}}
        {% if eq.is_root %}
          {{-"  "}}sol = {{eq.eq_id|eq_label("rhs")}};
        {% else %}
          {{-"  "}}sol = {{eq.eq_id|eq_label("rhs")}} - {{eq.eq_id|eq_label("lhs")}};
        {% endif %}
        {{-"\n"-}}
        {{-"  "}}sol = sol.value;
        {{-"\n"-}}
      {{-""}}endfunction
    {% endfor %}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%{{"\n"}}
  {% endif %}
{% endfor %}

% Auxiliar functions
function result = indexunion(varargin)
  result = varargin{1};
  for i = 2:nargin
    result = union(result, varargin{i});
  endfor
endfunction
