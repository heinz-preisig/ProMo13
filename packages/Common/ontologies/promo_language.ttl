promolg:in rdfs:label "in" ;
    rdfs:subClassOf promolg:operator .

promolg:inv rdfs:label "inv" ;
    rdfs:subClassOf promolg:function .

promolg:left rdfs:label "left" ;
    rdfs:subClassOf promolg:function .

promolg:left_round rdfs:label "(" ;
