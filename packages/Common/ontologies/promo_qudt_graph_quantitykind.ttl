<http://qudt.org/vocab/quantitykind/RF-Power> a ns1:QuantityKind ;
    rdfs:label "RF-Power Level"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/KiloV-PER-M>,
        <http://qudt.org/vocab/unit/MegaV-PER-M>,
