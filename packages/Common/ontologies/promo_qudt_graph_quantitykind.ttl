<http://qudt.org/vocab/quantitykind/PH> a ns1:QuantityKind ;
    rdfs:label "PH"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/PH> ;
    ns1:plainTextDescription "Chemicals or substances having a pH less than 7 are said to be acidic; more than 7 means basic." .

<http://qudt.org/vocab/quantitykind/PREDICTED-MASS> a ns1:QuantityKind ;
