        "放射エネルギー"@ja,
        "Tenaga sinaran"@ms,
        "energia promienista"@pl,
        "energia radiante"@pt,
        "энергия излучения"@ru,
        "Işınım erkesi"@tr,
        "辐射能"@zh ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/AttoJ>,
        <http://qudt.org/vocab/unit/BTU_IT>,
        <http://qudt.org/vocab/unit/BTU_TH>,
        <http://qudt.org/vocab/unit/CAL_IT>,
