<http://qudt.org/vocab/quantitykind/ElectricPropulsionPropellantMass> a ns1:QuantityKind ;
    rdfs:label "Electric Propulsion Propellant Mass"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/AMU>,
