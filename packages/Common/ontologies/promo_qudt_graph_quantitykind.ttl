        "sound pressure level"@en,
        "nivel de presión sonora"@es,
        "سطح یک کمیت توان-ریشه"@fa,
        "niveau de pression acoustique"@fr,
        "livello di pressione sonora"@it,
        "利得"@ja,
        "Tahap medan"@ms,
        "miary wielkości ilorazowych"@pl,
