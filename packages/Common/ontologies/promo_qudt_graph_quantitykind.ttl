    ns1:dbpediaMatch "http://dbpedia.org/resource/Force"^^xsd:anyURI ;
    ns1:latexDefinition "\\(F = \\frac{dp}{dt}\\), where \\(F\\) is the resultant force acting on a body, \\(p\\) is momentum of a body, and \\(t\\) is time."^^ns1:LatexString .

