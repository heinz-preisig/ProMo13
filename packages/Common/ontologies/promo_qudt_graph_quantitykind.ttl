<http://qudt.org/vocab/quantitykind/VaporPermeability> a ns1:QuantityKind ;
    rdfs:label "Vapor Permeability"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/KiloGM-PER-M2-PA-SEC>,
        <http://qudt.org/vocab/unit/NanoGM-PER-M2-PA-SEC>,
        <http://qudt.org/vocab/unit/PERM_Metric>,
        <http://qudt.org/vocab/unit/PERM_US> ;
    ns1:plainTextDescription "Vapour permeability, or \"Breathability\" in a building refers to the ease with which water vapour passes through building elements. Building elements where vapour permeability is poorly designed can result in condensation, leading to unhealthy living environments and degradation of fabric." .

