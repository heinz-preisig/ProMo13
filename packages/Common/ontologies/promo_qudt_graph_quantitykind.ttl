    ns1:latexDefinition "\\(P_a = IA\\), where \\(I\\) is the sound intensity in \\(\\frac{W}{m^2}\\) and \\(A\\) is the area in \\(m^2\\)."^^ns1:LatexString .

<http://qudt.org/vocab/quantitykind/SoundPowerLevel> a ns1:QuantityKind ;
