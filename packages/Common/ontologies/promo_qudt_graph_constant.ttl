<http://qudt.org/vocab/constant/AvogadroConstant> a ns1:PhysicalConstant ;
    rdfs:label "Avogadro constant"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/PER-MOL> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Avogadro_constant"^^xsd:anyURI ;
    ns1:latexDefinition "\\(L = \\frac{N}{n}\\), where \\(N\\) is the number of particles and \\(n\\) is amount of substance."^^ns1:LatexString .

<http://qudt.org/vocab/constant/BohrMagneton> a ns1:PhysicalConstant ;
    rdfs:label "Bohr Magneton"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/J-PER-T> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Bohr_magneton"^^xsd:anyURI ;
    ns1:latexDefinition "\\(\\mu_B = \\frac{e\\hbar}{2m_e}\\), where \\(e\\) is the elementary charge, \\(\\hbar\\) is the Planck constant, and \\(m_e\\) is the rest mass of electron."^^ns1:LatexString .

<http://qudt.org/vocab/constant/BohrMagnetonInEVPerT> a ns1:PhysicalConstant ;
    rdfs:label "Bohr magneton in eV per T"@en .

<http://qudt.org/vocab/constant/BohrMagnetonInHzPerT> a ns1:PhysicalConstant ;
    rdfs:label "Bohr magneton in Hz perT"@en .

<http://qudt.org/vocab/constant/BohrMagnetonInInverseMetersPerTesla> a ns1:PhysicalConstant ;
    rdfs:label "Bohr magneton in inverse meters per tesla"@en .

<http://qudt.org/vocab/constant/BohrMagnetonInKPerT> a ns1:PhysicalConstant ;
    rdfs:label "Bohr magneton in K per T"@en .

<http://qudt.org/vocab/constant/BohrRadius> a ns1:PhysicalConstant ;
    rdfs:label "Bohr Radius"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/M> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Bohr_radius"^^xsd:anyURI ;
    ns1:latexDefinition "\\(a_0 = \\frac{4\\pi \\varepsilon_0 \\hbar^2}{m_ee^2}\\), where \\(\\varepsilon_0\\) is the electric constant, \\(\\hbar\\) is the reduced Planck constant, \\(m_e\\)  is the rest mass of electron, and \\(e\\) is the elementary charge."^^ns1:LatexString .

<http://qudt.org/vocab/constant/BoltzmannConstant> a ns1:PhysicalConstant ;
    rdfs:label "Boltzmann Constant"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/J-PER-K> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Boltzmann_constant"^^xsd:anyURI .

<http://qudt.org/vocab/constant/BoltzmannConstantInEVPerK> a ns1:PhysicalConstant ;
    rdfs:label "Boltzmann constant in eV per K"@en .

<http://qudt.org/vocab/constant/BoltzmannConstantInHzPerK> a ns1:PhysicalConstant ;
    rdfs:label "Boltzmann constant in Hz per K"@en .

<http://qudt.org/vocab/constant/BoltzmannConstantInInverseMetersPerKelvin> a ns1:PhysicalConstant ;
    rdfs:label "Boltzmann constant in inverse meters per kelvin"@en .

