<http://qudt.org/vocab/constant/HartreeEnergy> a ns1:AtomicUnit,
        ns1:PhysicalConstant ;
    rdfs:label "Hartree Energy"@en ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Hartree"^^xsd:anyURI ;
    ns1:latexDefinition "\\(E_H= \\frac{e^2}{4\\pi \\varepsilon_0 a_0 }\\), where \\(e\\) is the elementary charge, \\(\\varepsilon_0\\) is the electric constant, and \\(a_0\\) is the Bohr radius."^^ns1:LatexString .

<http://qudt.org/vocab/constant/HartreeEnergyInEV> a ns1:PhysicalConstant ;
