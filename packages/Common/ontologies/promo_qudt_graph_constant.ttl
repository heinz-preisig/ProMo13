<http://qudt.org/vocab/constant/ComptonWavelength> a ns1:PhysicalConstant ;
    rdfs:label "Compton Wavelength"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/M> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Compton_wavelength"^^xsd:anyURI ;
    ns1:latexDefinition "\\(\\lambda_C = \\frac{h}{mc_0}\\), where \\(h\\) is the Planck constant, \\(m\\) is the rest mass of a particle, and \\(c_0\\) is the speed of light in vacuum."^^ns1:LatexString .

<http://qudt.org/vocab/constant/ComptonWavelengthOver2Pi> a ns1:PhysicalConstant ;
    rdfs:label "Compton wavelength over 2 pi"@en .

