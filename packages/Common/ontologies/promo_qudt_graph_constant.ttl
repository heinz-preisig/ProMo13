<http://qudt.org/vocab/constant/ElectromagneticPermeabilityOfVacuum> a ns1:PhysicalConstant ;
    rdfs:label "Permeability of Vacuum"@en ;
    ns1:applicableUnit <http://qudt.org/vocab/unit/H-PER-M> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Vacuum_permeability"^^xsd:anyURI ;
    ns1:latexDefinition "\\(\\mu_0 = \\frac{\\overrightarrow{B}}{\\overrightarrow{H}}\\), where \\(\\overrightarrow{B}\\) is the B-Filed magnetic vector, and \\(\\overrightarrow{H}\\) is the H-Field magnetic vector. The value of \\(\\mu_0\\) is \\(\\approx 1.256637e-6\\,henry\\,per\\,metre\\)."^^ns1:LatexString .

