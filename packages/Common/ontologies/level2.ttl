@prefix promo: <http://example.org#> .
@prefix promolg: <http://example.org/language#> .
@prefix qudt: <http://qudt.org/2.1/vocab/quantitykind#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

promo:aliases a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:List .

promo:charge a promo:token .

<http://example.org#control+A> a promo:variable ;
    promo:doc "dynamic matrix" ;
    promo:has_index promo:diffSpace,
        promo:node ;
    promo:label "A" ;
    promo:network "control" ;
    promo:port_variable "True" ;
    promo:type "constant" ;
    promo:unit_amount 0 ;
    promo:unit_current 0 ;
    promo:unit_length 0 ;
    promo:unit_light 0 ;
    promo:unit_mass 0 ;
    promo:unit_nil 0 ;
    promo:unit_temperature 0 ;
    promo:unit_time -1 ;
    qudt:A promo:unit_current ;
    qudt:CD promo:unit_light ;
    qudt:K promo:unit_temperature ;
    qudt:KiloGM promo:unit_mass ;
    qudt:M promo:unit_length ;
    qudt:MOL promo:unit_amount ;
    qudt:SEC promo:unit_time ;
    qudt:UNITLESS promo:unit_nil .

