promo:energy a promo:token .

promo:equations a rdfs:class .

promo:expression_list a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:List .

promo:global_index_list rdf:_1 promo:node ;
    rdf:_2 promo:arc ;
    rdf:_3 promo:species ;
    rdf:_4 promo:species_conversion ;
    rdf:_5 promo:node_x_species ;
    rdf:_6 promo:arc_x_species ;
    rdf:_7 promo:node_x_species_conversion ;
    rdf:_8 promo:species_conversion_x_species ;
    rdf:_9 promo:diffSpace .

promo:has_index a rdfs:property .

promo:index_structures a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:List .

promo:indices a rdf:Property ;
    rdfs:domain promo:blockIndex ;
    rdfs:range rdfs:List .

promo:label a rdf:Property ;
    rdfs:domain rdfs:blockIndex,
        rdfs:index ;
    rdfs:range rdfs:Literal .

<http://example.org#macroscopic+AmountOfSubstanceAccumulation> a promo:variable ;
    promo:doc "differential species balance" ;
    promo:has_index promo:node_x_species ;
    promo:label "dndt" ;
    promo:network "macroscopic" ;
    promo:port_variable "False" ;
    promo:type "diffState" ;
    promo:unit_amount 1 ;
    promo:unit_current 0 ;
    promo:unit_length 0 ;
    promo:unit_light 0 ;
    promo:unit_mass 0 ;
    promo:unit_nil 0 ;
    promo:unit_temperature 0 ;
    promo:unit_time -1 ;
    qudt:A promo:unit_current ;
    qudt:CD promo:unit_light ;
    qudt:K promo:unit_temperature ;
    qudt:KiloGM promo:unit_mass ;
    qudt:M promo:unit_length ;
    qudt:MOL promo:unit_amount ;
    qudt:SEC promo:unit_time ;
    qudt:UNITLESS promo:unit_nil .

