    rdfs:label "Quartic Millimetre"@en,
        "Quartic Millimeter"@en-us ;
    ns1:plainTextDescription "0.001-fold of the power of the SI base unit metre with the exponent 4" .

<http://qudt.org/vocab/unit/MilliMOL> a ns1:Unit ;
