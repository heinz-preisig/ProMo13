    ns1:plainTextDescription "0.000001-fold of the power of the SI base unit metre with the exponent 2" .

<http://qudt.org/vocab/unit/MilliM2-PER-SEC> a ns1:Unit ;
    rdfs:label "Square Millimetre Per Second"@en,
