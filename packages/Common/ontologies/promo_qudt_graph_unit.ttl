        "\\(1 C \\leftrightarrow 4 \\pi \\times 2997924580 statC \\approx 3.77 \\times 10^{10} statC,\\ 1 \\hspace{0.3pc} statC \\leftrightarrow \\hspace{0.2pc} \\approx 2.6 \\times 10^{-11} C\\) for electric flux \\(\\Phi_D\\)"^^ns1:LatexString,
