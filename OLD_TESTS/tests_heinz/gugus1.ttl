@prefix promo: <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

promo:aliases a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:doc a rdf:Property ;
    rdfs:domain promo:equation ;
    rdfs:range rdfs:comment .

promo:energy a promo:token .

promo:equation_list a rdf:Collection ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:incidence_list a rdf:Seq ;
    rdfs:domain promo:equation .

promo:index_structures a rdf:Collection ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:mass a promo:token .

promo:network a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:present_token a rdfs:class .

promo:rhs a rdf:Property ;
    rdfs:domain promo:equation ;
    rdfs:range rdfs:Literal .

promo:units a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:v1 promo:network "physical" ;
    promo:present_token "[False, False]" ;
    promo:var_name "U" .

promo:var_name a promo:name .

promo:name a rdf:Property ;
    rdfs:range rdfs:Literal .

promo:token a rdfs:class .

promo:equation a rdfs:class .

promo:variable a rdfs:class .

