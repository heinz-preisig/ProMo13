promo:EnergyInternal promo:has_tokens promo:t_1 ;
    rdf:_1 promo:e_1s .

promo:Entropy promo:network "physical" ;
    promo:tokens promo:t_2 ;
    rdf:Seq promo:e_2s .

promo:aliases a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:doc a rdf:Property ;
    rdfs:domain promo:equation ;
    rdfs:range rdfs:comment .

promo:equation_list a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:List .

promo:expressions a rdf:Property ;
    rdfs:domain promo:expression ;
    rdfs:range rdfs:List .

promo:incidence_list a rdf:Property ;
    rdfs:domain promo:equation .

promo:index_structures a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:List .

promo:network a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:rhs a rdf:Property ;
    rdfs:domain promo:equation ;
    rdfs:range rdfs:List .

promo:tokens a rdf:Property ;
    rdfs:domain promo:variables ;
    rdfs:range rdfs:List .

promo:units a rdf:Property ;
    rdfs:domain promo:variable ;
    rdfs:range rdfs:Literal .

promo:var_name a promo:name .

<http://qudt.org/schema/qudt/EnergyInternal> a promo:variable ;
    promo:has_unit <http://qudt.org/schema/qudt/KiloGM> ;
    promo:network "physical" .

<http://qudt.org/schema/qudt/Entropy> a promo:variable .

promo:e_1 rdf:_1 promo:left_round ;
    rdf:_2 promo:v_2 ;
    rdf:_3 promo:plus ;
    rdf:_4 promo:v_3 ;
    rdf:_5 promo:right_round .

promo:e_1s rdf:_1 promo:e_1,
        promo:e_2,
        promo:e_3 .

promo:e_2s rdf:_1 promo:e_3 .

promo:expression a rdfs:class .

promo:mass a promo:token .

promo:name a rdf:Property ;
    rdfs:range rdfs:Literal .

promo:t_1 rdf:_1 promo:mass ;
    rdf:_2 promo:energy .

promo:t_2 rdf:_1 promo:energy .

promo:energy a promo:token .

promo:token a rdfs:class .

promo:equation a rdfs:class .

promo:variable a rdfs:class .

