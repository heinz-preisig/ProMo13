    ns1:latexSymbol "\\(\\tau, \\tau_n, \\tau_p\\)"^^ns1:LatexString ;
    ns1:plainTextDescription "\"Carrier LifetIme\" is a time constant for recombination or trapping of minority charge carriers in semiconductors." ;
