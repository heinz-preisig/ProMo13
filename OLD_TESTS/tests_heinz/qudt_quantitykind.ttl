        <http://qudt.org/vocab/unit/KiloGM-M2-PER-SEC>,
        <http://qudt.org/vocab/unit/N-M-SEC> ;
    ns1:hasDimensionVector <http://qudt.org/vocab/dimensionvector/A0E0L2I0M1H0T-1D0> ;
