    rdfs:seeAlso <http://qudt.org/vocab/quantitykind/DiastolicBloodPressure> ;
    skos:broader <http://qudt.org/vocab/quantitykind/Pressure> .

<http://qudt.org/vocab/quantitykind/TemperaturePerTime> a ns1:QuantityKind ;
