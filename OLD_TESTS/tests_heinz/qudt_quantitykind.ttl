        <http://qudt.org/vocab/unit/K-PER-MIN>,
        <http://qudt.org/vocab/unit/K-PER-SEC> ;
    ns1:hasDimensionVector <http://qudt.org/vocab/dimensionvector/A0E0L0I0M0H1T-1D0> ;
