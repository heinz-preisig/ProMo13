        <http://qudt.org/vocab/unit/PlanckPressure>,
        <http://qudt.org/vocab/unit/TORR> ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Atmospheric_pressure"^^xsd:anyURI ;
