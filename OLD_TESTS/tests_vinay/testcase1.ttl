@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/> .


# NOTE this model handles multiple addresses and a nick name for a person by adding two more properties to simpler case!
# Observe that that the same property ex:address is used multiple times to assert the multiple addresses for a person.


# Define the entity
ex:person a rdfs:Class .

# Define the properties
ex:fullName a rdf:Property ;
      rdfs:domain ex:person ;
      rdfs:range rdfs:Literal .

ex:nickName a rdf:Property ;
      rdfs:domain ex:person ;
      rdfs:range rdfs:Literal .

ex:age a rdf:Property ;
      rdfs:domain ex:person ;
      rdfs:range xsd:integer .

ex:address a rdf:Property ;
         rdfs:domain ex:person ;
         rdfs:range rdfs:Literal .

# Assert the attributes of the entity
ex:Vinay ex:fullName "Vinay Gautam" ;
         ex:nickName "Vin" ;
         ex:age 42 ;
         ex:address "Road Trondheim" ;
         ex:address "Street Bergen" .

ex:Heinz ex:fullName "Heinz Preisig" ;
         ex:nickName "Heinzy" ;
         ex:age 72 ;
         ex:address "Road In" ;
         ex:address "Street Zurich" .
