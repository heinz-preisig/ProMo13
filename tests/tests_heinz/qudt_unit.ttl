    ns1:iec61360Code "0112/2///62720#UAA469" ;
    ns1:plainTextDescription "0,001-fold of the SI base unit kilogram divided by the 0.000 001-fold of the power of the SI base unit metre with the exponent 3" ;
    ns1:symbol "g/cm³" ;
    ns1:ucumCode "g.cm-3"^^ns1:UCUMcs,
        "g/cm3"^^ns1:UCUMcs ;
    ns1:uneceCommonCode "23" ;
    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
        <http://qudt.org/vocab/unit> .

<http://qudt.org/vocab/unit/GM-PER-DAY> a ns1:Unit ;
    rdfs:label "Gram Per Day"@en ;
