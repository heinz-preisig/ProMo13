    ns1:symbol "N/m" ;
    ns1:ucumCode "N.m-1"^^ns1:UCUMcs,
        "N/m"^^ns1:UCUMcs ;
    ns1:uneceCommonCode "4P" ;
    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
        <http://qudt.org/vocab/unit> .

