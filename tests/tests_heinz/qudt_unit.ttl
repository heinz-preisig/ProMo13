    ns1:ucumCode "Pa2.s"^^ns1:UCUMcs ;
    ns1:uneceCommonCode "P42" ;
    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
        <http://qudt.org/vocab/unit> .

<http://qudt.org/vocab/unit/PAB> a ns1:CurrencyUnit,
        ns1:Unit ;
    rdfs:label "Balboa"@en ;
