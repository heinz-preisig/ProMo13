    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
        <http://qudt.org/vocab/unit> .

<http://qudt.org/vocab/unit/HP> a ns1:Unit ;
    rdfs:label "Horsepower"@en ;
    dcterms:description "550 foot-pound force per second"^^rdf:HTML ;
