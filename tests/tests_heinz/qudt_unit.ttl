    ns1:symbol "kg/m" ;
    ns1:ucumCode "kg.m-1"^^ns1:UCUMcs,
        "kg/m"^^ns1:UCUMcs ;
    ns1:uneceCommonCode "KL" ;
    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
