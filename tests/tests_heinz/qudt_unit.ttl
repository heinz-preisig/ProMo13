    ns1:hasDimensionVector <http://qudt.org/vocab/dimensionvector/A0E0L3I0M0H0T-2D0> ;
    ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/StandardGravitationalParameter> ;
    ns1:symbol "m³/s²" ;
    ns1:ucumCode "m3.s-2"^^ns1:UCUMcs,
