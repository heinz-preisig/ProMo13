<http://qudt.org/vocab/unit/BTU_IT-FT-PER-FT2-HR-DEG_F> a ns1:DerivedUnit,
        ns1:Unit ;
    rdfs:label "BTU (IT) Foot per Square Foot Hour Degree Fahrenheit"@en ;
    dcterms:description "\\(BTU_{IT}\\), Foot per Square Foot Hour Degree Fahrenheit</em> is an Imperial unit for 'Thermal Conductivity' expressed as \\(Btu_{it} \\cdot ft/(hr \\cdot ft^2  \\cdot degF)\\)."^^ns1:LatexString ;
    ns1:conversionMultiplier 1.730734666 ;
    ns1:expression "\\(Btu(IT) ft/(hr ft^2 degF)\\)"^^ns1:LatexString ;
    ns1:hasDimensionVector <http://qudt.org/vocab/dimensionvector/A0E0L1I0M1H-1T-3D0> ;
