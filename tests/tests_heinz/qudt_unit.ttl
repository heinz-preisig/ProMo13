    ns1:symbol "mmHg" ;
    ns1:ucumCode "mm[Hg]"^^ns1:UCUMcs ;
    ns1:udunitsCode "mmHg",
        "mm_Hg",
        "mm_hg",
        "mmhg" ;
    ns1:uneceCommonCode "HN" ;
