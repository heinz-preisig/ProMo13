<http://qudt.org/vocab/unit/B> a ns1:DimensionlessUnit,
        ns1:LogarithmicUnit,
        ns1:Unit ;
    rdfs:label "Bel"@en ;
    dcterms:description "A logarithmic unit of sound pressure equal to 10 decibels (dB),  It is defined as: \\(1 B = (1/2) \\log_{10}(Np)\\)"^^ns1:LatexString ;
    ns1:dbpediaMatch "http://dbpedia.org/resource/Bel"^^xsd:anyURI ;
