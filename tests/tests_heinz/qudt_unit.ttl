    dcterms:description "\\({\\bf BTU \\, per \\, Square \\, Foot \\, Hour \\, Degree \\, Fahrenheit}\\) is an Imperial unit for 'Coefficient Of Heat Transfer' expressed as \\(Btu/(hr-ft^{2}-degF)\\)."^^ns1:LatexString ;
