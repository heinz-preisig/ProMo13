    ns1:ucumCode "cal_[15]"^^ns1:UCUMcs ;
    ns1:uneceCommonCode "A1" ;
    rdfs:isDefinedBy <http://qudt.org/2.1/vocab/unit>,
        <http://qudt.org/vocab/unit> .

