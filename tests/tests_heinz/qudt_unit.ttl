<http://qudt.org/vocab/unit/M2-PER-SEC> a ns1:DerivedUnit,
        ns1:Unit ;
    rdfs:label "Square Metre per Second"@en,
        "Square Meter per Second"@en-us ;
    dcterms:description "\\(Square Metres per second is the SI derived unit of angular momentum, defined by distance or displacement in metres multiplied by distance again in metres and divided by time in seconds. The unit is written in symbols as m2/s or m2u00b7s-1 or m2s-1. It may be better understood when phrased as \"metres per second times metres\", i.e. the momentum of an object with respect to a position.\\)"^^ns1:LatexString ;
    ns1:conversionMultiplier 1.0 ;
    ns1:definedUnitOfSystem <http://qudt.org/vocab/sou/SI> ;
    ns1:derivedCoherentUnitOfSystem <http://qudt.org/vocab/sou/SI> ;
    ns1:expression "\\(m^{2} s^{-1}\\)"^^ns1:LatexString ;
    ns1:hasDimensionVector <http://qudt.org/vocab/dimensionvector/A0E0L2I0M0H0T-1D0> ;
    ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/AreaPerTime>,
