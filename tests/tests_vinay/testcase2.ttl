@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/> .

#NOTE: In this case, entity person has more than one attribute (e.g., name and nickname and address1 and address2)  that is represented by properties. 
#To handle multiple attributes of the entity type person, blank nodes are used.



# Define the entity
ex:person a rdfs:Class .

# Define the properties
ex:personName a rdf:Property ;
      rdfs:domain ex:person ;
      rdfs:range rdfs:Literal .

ex:personAge a rdf:Property ;
      rdfs:domain ex:person ;
      rdfs:range xsd:integer .

ex:personAddress a rdf:Property ;
         rdfs:domain ex:person ;
         rdfs:range rdfs:Literal .

# Assert the attributes of the entity
_:vinay a ex:person ;
       ex:personName "Vinay Gautam" ;
       ex:personName "Vinny" ;
       ex:personAge 42 ;
       ex:personAddress "road Trondheim" ;
       ex:personAddress "street X".

_:heinz a ex:person ;
       ex:personName "Heinz Preisig" ;
       ex:personName "Heinie" ;
       ex:personAge 72 ;
       ex:personAddress "road A" ;
       ex:personAddress "road B".



